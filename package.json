{
  "name": "pingguard",
  "version": "2.0.0",
  "private": true,
  "description": "PingGuard is a public Discord bot for visual mass-ping spam protection.",
  "type": "module",
  "main": "dist/main.js",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/infrastructure/database/migrate.ts",
    "db:check": "drizzle-kit check",
    "commands:dev": "tsx src/discord/commands/register.ts --dev",
    "commands:global": "tsx src/discord/commands/register.ts --global"
  },
  "keywords": [
    "discord",
    "moderation",
    "typescript",
    "postgres",
    "security"
  ],
  "license": "MIT",
  "dependencies": {
    "discord.js": "14.27.0",
    "dotenv": "16.4.7",
    "drizzle-orm": "0.45.2",
    "fastify": "5.10.0",
    "pg": "8.22.0",
    "pino": "10.3.1",
    "prom-client": "15.1.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/pg": "8.20.0",
    "@typescript-eslint/eslint-plugin": "8.64.0",
    "@typescript-eslint/parser": "8.64.0",
    "@vitest/coverage-v8": "4.1.10",
    "drizzle-kit": "0.31.10",
    "eslint": "10.7.0",
    "fast-check": "4.9.0",
    "prettier": "3.9.5",
    "pino-pretty": "13.1.3",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "overrides": {
    "esbuild": "0.28.1"
  }
}
